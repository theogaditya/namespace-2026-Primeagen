# ===========================================
# AI Agents Service Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
PORT=3040

# Model Provider: openai | google | anthropic
MODEL_PROVIDER=openai

# Primary model (for complex reasoning)
MODEL_CHAT=gpt-4o

# Fast model (for guardrails, abuse detection, quick tasks)
MODEL_FAST=gpt-4o-mini

# OpenAI API Key (for GPT, Whisper STT, TTS)
OPENAI_API_KEY=your-openai-api-key

# Google API Key (optional -for Gemini swap)
GOOGLE_API_KEY=your-google-api-key

# Hugging Face API Key (for toxicity detection with unitary/unbiased-toxic-roberta)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-api-key
# Optional: explicit router endpoint for the RoBERTa toxicity model
TOXICITY_DETECTOR_ENDPOINT_URL=https://router.huggingface.co/hf-inference/models/unitary/unbiased-toxic-roberta
# Optional: temporarily disable the HF toxicity detector after repeated API failures
TOXICITY_DETECTOR_COOLDOWN_MS=600000
# Optional: use a longer cooldown for fatal HF failures like blob fetch/access errors
TOXICITY_DETECTOR_FATAL_COOLDOWN_MS=3600000
# Optional: extra retries for explicit "model loading" responses; default is 1 because the HF client already retries 503s internally
TOXICITY_DETECTOR_MAX_RETRIES=1

# Database (read-only recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/swarajdesk?schema=public

# Redis (session memory, rate limiting)
REDIS_URL=redis://localhost:6379

# JWT Secret (same as user-be -validates user tokens)
JWT_SECRET=my123

# Self Service URL (for image analysis)
SELF_SERVICE_URL=http://localhost:3030

# Support Email (used for ALL email needs -Help AI escalation, references)
SUPPORT_EMAIL=adityahota99@gmail.com

# SMTP Configuration (for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Internal API Key (service-to-service auth for /api/moderate endpoint)
INTERNAL_API_KEY=your-internal-api-key

# LangSmith Observability (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key
