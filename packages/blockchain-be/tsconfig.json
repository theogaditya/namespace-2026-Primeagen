{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["node", "express", "cors"]
  },
  "include": ["./src", "./backend/src", "./test", "./scripts", "hardhat.config.ts", "typechain-types"]
}