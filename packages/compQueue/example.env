# ===========================================
# Complaint Queue Microservice Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
COMP_QUEUE_PORT=3005

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/swarajdesk?schema=public

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AWS Secrets Manager (for production)
SECRET_NAME_AWS_USER_BE=sih-swaraj-user-be
AWS_REGION=ap-south-2
SECRETS_AWS_ACCESS_KEY_ID=your-aws-access-key
SECRETS_AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Categorization API (for AI standardization)
CATEGORIZATION_API_URL=https://cat-ani.adityahota.online/predict

# Moderation Service (now via agents service -Abuse AI)
AGENTS_SERVICE_URL=http://localhost:3040
INTERNAL_API_KEY=your-internal-api-key
