# Redis Configuration
# Preferred Redis connection string
REDIS_URL="redis://localhost:6379"

# Optional fallback when REDIS_URL is not provided
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=

# Blockchain Configuration
BLOCKCHAIN_RPC_URL="Your_Blockchain_RPC_URL_Here"
PRIVATE_KEY="Your_Private_Key_Here"
CONTRACT_ADDRESS="Your_Contract_Address_Here"

# IPFS Configuration
PINATA_JWT="Your_Pinata_JWT_Here"

# Optional Pinata API credentials (not required by current worker runtime)
PINATA_API_KEY=
PINATA_API_SECRET=

# Worker Configuration
WORKER_POLL_INTERVAL="5000"
MAX_RETRIES="5"
MAX_TX_RETRIES="3"
BASE_RETRY_DELAY_MS="1000"
MAX_RETRY_DELAY_MS="30000"

# Queue Configuration
USER_QUEUE_NAME="user:registration:queue"
COMPLAINT_QUEUE_NAME="complaint:registration:queue"
METADATA_SYNC_QUEUE="blockchain:metadata:queue"

# Optional: Backend metadata sync endpoint for DB updates
BACKEND_SYNC_URL="http://localhost:4000/internal/blockchain/sync"
BACKEND_SYNC_TOKEN=

# Optional: Keep this for legacy compatibility
QUEUE_NAME=

# Optional: emit on-chain event when generating verification code
EMIT_VERIFICATION_CODE_TX="true"

# Optional deployment/CI variables
AWS_REGION="ap-south-1"
SLACK_WEBHOOK_URL=
