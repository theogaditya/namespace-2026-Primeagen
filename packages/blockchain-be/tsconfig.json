{
  "compilerOptions": {
    "rootDir": "./src",
    "target": "es2020",
    "module": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node16", 
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["./src"]
}