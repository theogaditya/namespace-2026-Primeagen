# ===========================================
# User Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# User Backend API URL
NEXT_PUBLIC_USER_BE_URL=http://localhost:3000

# Blockchain verification backend URL
NEXT_PUBLIC_BLOCKCHAIN_BE_URL=http://localhost:4000

# reCAPTCHA v2 Site Key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# WebSocket URL (for real-time features)
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# Google Maps API Key (for location features)
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-maps-api-key

# Agents Service (Sentient AI)
AGENTS_SERVICE_URL=http://localhost:3040
INTERNAL_API_KEY=your-internal-api-key

# Image Analysis Service
NEXT_PUBLIC_IMAGE_ANALYSIS_API_URL=http://localhost:3040/api/image

# PIN Code API
NEXT_PUBLIC_PIN_API_BASE=https://api.postalpincode.in/pincode

# Admin Backend URL (optional - for some features)
NEXT_PUBLIC_API_URL=http://localhost:3002

# Backend URL (server-side)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
USER_BE_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000
